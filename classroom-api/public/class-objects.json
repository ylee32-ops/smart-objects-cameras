{
  "objects": [
    {
      "id": "ambient-light",
      "label": "Ambient Light Sensor",
      "kind": "sensor",
      "surface": "room",
      "eventType": "sensor.light.changed",
      "description": "Simulates room light level and implicit lamp response.",
      "state": { "level": 32, "mode": "dusk" },
      "controls": [
        { "id": "level", "label": "Light level", "type": "range", "min": 0, "max": 100, "step": 1 },
        { "id": "mode", "label": "Mode", "type": "select", "options": ["night", "dusk", "class", "bright"] }
      ]
    },
    {
      "id": "zone-response",
      "label": "Zone Response Map",
      "kind": "zone",
      "surface": "room",
      "eventType": "zone.entered",
      "description": "Simulates entering podium, whiteboard, collaboration, or entrance zones.",
      "state": { "zone": "podium", "object": "Instructor" },
      "controls": [
        { "id": "zone", "label": "Zone", "type": "select", "options": ["podium", "whiteboard", "collaboration", "entrance"] },
        { "id": "object", "label": "Object", "type": "select", "options": ["Instructor", "Whiteboard Marker", "Student Notebook", "Coffee Mug"] }
      ]
    },
    {
      "id": "rule-engine",
      "label": "Declarative Rule Engine",
      "kind": "rule",
      "surface": "room",
      "eventType": "rule.triggered",
      "description": "Simulates if/then classroom rules from objects.json.",
      "state": { "rule": "Presentation Mode", "active": true },
      "controls": [
        { "id": "rule", "label": "Rule", "type": "select", "options": ["Presentation Mode", "Whiteboard Active", "Collaboration"] },
        { "id": "active", "label": "Active", "type": "toggle" }
      ]
    },
    {
      "id": "live-object-stream",
      "label": "Live Object Stream",
      "kind": "object",
      "surface": "room",
